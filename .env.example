# Personal Work Agent — environment variable reference
# Copy this file to .env and edit as needed.
# All variables are optional; the defaults listed here are the built-in defaults.

# ── Data storage ────────────────────────────────────────────────────────────
# AGENT_DATA_DIR=~/.agent

# ── Embedding model (local, no network required) ────────────────────────────
# AGENT_EMBED_MODEL=all-MiniLM-L6-v2

# ── Web server ───────────────────────────────────────────────────────────────
# AGENT_HOST=127.0.0.1
# AGENT_PORT=8000
# AGENT_LOG_LEVEL=info

# ── LLM provider (disabled by default) ──────────────────────────────────────
# Set AGENT_LLM_PROVIDER to "ollama" or "openai" to enable chat features.
#
# Example — local Ollama:
# AGENT_LLM_PROVIDER=ollama
# AGENT_LLM_MODEL=llama3.2
# AGENT_LLM_BASE_URL=http://localhost:11434
#
# Example — OpenAI or compatible API:
# AGENT_LLM_PROVIDER=openai
# AGENT_LLM_MODEL=gpt-4o-mini
# AGENT_LLM_BASE_URL=https://api.openai.com/v1
# AGENT_LLM_API_KEY=sk-...
#
AGENT_LLM_PROVIDER=none
# AGENT_LLM_MODEL=llama3.2
# AGENT_LLM_BASE_URL=http://localhost:11434
# AGENT_LLM_API_KEY=
